{
  "name": "tasarubat",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "postinstall": "patch-package",
    "dev": "next dev",
    "build": "next build",
    "build:static": "node scripts/static-export-build.mjs",
    "sync:pages-redirects": "node scripts/sync-pages-redirects.mjs",
    "deploy:pages": "npm run build:static && node scripts/pages-deploy.mjs",
    "preview:pages": "wrangler pages dev out",
    "start": "next start",
    "lint": "next lint",
    "cf:build": "opennextjs-cloudflare build",
    "preview:cf": "opennextjs-cloudflare build && wrangler dev",
    "deploy:cf": "node scripts/deploy-cf.cjs",
    "export:blog-slugs": "node scripts/export-d1-blog-slugs.cjs",
    "articles:from-demo": "npx tsx scripts/export-demo-to-md.ts",
    "articles:export-from-d1": "node scripts/export-d1-articles-to-md.cjs",
    "db:migrate:local": "wrangler d1 migrations apply tasarubat-articles --local",
    "db:migrate:remote": "wrangler d1 migrations apply tasarubat-articles --remote",
    "process-logo": "node scripts/remove-logo-black-bg.cjs",
    "index:google": "node scripts/google-indexing-notify.cjs"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.1",
    "@opennextjs/cloudflare": "^1.19.5",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "gray-matter": "^4.0.3",
    "lucide-react": "^1.14.0",
    "next": "^15.5.15",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "shadcn": "^4.6.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260430.1",
    "@tailwindcss/typography": "^0.5.19",
    "@types/node": "^20",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "drizzle-kit": "^0.31.10",
    "eslint": "^8",
    "eslint-config-next": "^15.5.15",
    "patch-package": "^8.0.1",
    "postcss": "^8",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.4.1",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "wrangler": "^4.86.0"
  }
}
