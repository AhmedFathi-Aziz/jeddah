# عنوان الموقع الكامل (لـ metadataBase و sitemap و JSON-LD)
NEXT_PUBLIC_SITE_URL=https://example.com

# Google Analytics 4 — Measurement ID (يُفعّل gtag.js و`window.gtag` في كل الصفحات)
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# ——— Google Indexing API (سكربت: npm run index:google) ———
# مسار ملف JSON لحساب الخدمة (مفضّل في CI؛ لا ترفع الملف إلى git)
# GOOGLE_INDEXING_CREDENTIALS_PATH=./secrets/indexing-sa.json
# أو متغير Google القياسي:
# GOOGLE_APPLICATION_CREDENTIALS=D:\secrets\indexing-sa.json
# مسارات نسبية للموقع (تُجمَع مع NEXT_PUBLIC_SITE_URL أعلاه)
# INDEXING_NOTIFY_PATHS=/,/services,/leak-detection,/blog/slug-here
# INDEXING_NOTIFICATION_TYPE=URL_UPDATED
# لحذف من الفهرس: INDEXING_NOTIFICATION_TYPE=URL_DELETED
